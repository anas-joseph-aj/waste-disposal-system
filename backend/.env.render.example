# Render production environment example
NODE_ENV=production
PORT=10000
PRIMARY_DB=mongo

# Frontend origin (your Vercel site)
CLIENT_URL=https://waste-disposal-system.vercel.app
CLIENT_URLS=https://waste-disposal-system.vercel.app

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_with_long_random_secret

# Optional fallback mode support
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
