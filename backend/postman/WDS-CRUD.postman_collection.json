              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create User status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "const userId = jsonData?.user?._id;",
