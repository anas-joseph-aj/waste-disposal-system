{
  "name": "waste-disposal-system",
  "private": true,
  "version": "1.0.0",
  "description": "Run frontend and backend together for local development",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix backend\" \"http-server . -p 0 -c-1\"",
    "start": "concurrently \"npm run start --prefix backend\" \"http-server . -p 0 -c-1\"",
    "db:seed": "npm run db:seed --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "http-server": "^14.1.1"
  }
}
